# Routing voor de Apache/LiteSpeed-host.
#
# De site is geprerenderd: elke route staat als <route>/index.html in de build.
# Daarnaast hydrateert er een client-side SPA overheen.
#
# 1) Geprerenderde routes serveren we ZONDER trailing-slash-redirect, zodat de
#    URL zonder slash (zoals in de sitemap, canonicals en interne links) direct
#    met status 200 wordt geserveerd (geen 301 naar /pad/).
# 2) Bestaande bestanden (assets, afbeeldingen, redirect-stubs) gaan ongemoeid.
# 3) Al het overige valt terug op de SPA-entry (index.html), zodat onbekende
#    deep links niet hard 404'en maar de router de pagina laat afhandelen.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # www -> apex (kevinfroger.nl) zodat er geen dubbele host bestaat.
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Geen automatische "voeg trailing slash toe"-301 voor mappen.
  DirectorySlash Off

  # Geprerenderde route (map met index.html) direct serveren op de URL zonder slash.
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]

  # Bestaande bestanden en mappen ongemoeid serveren.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Al het overige naar de SPA-entry (200, geen 404).
  RewriteRule ^ /index.html [L]
</IfModule>
